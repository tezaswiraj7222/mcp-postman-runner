{
      "info": {
        "name": "Smoke Test Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "item": [
        {
          "name": "Smoke Test Folder",
          "item": [
            {
              "name": "Test POST Payload",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-Smoke-Test", "value": "Antigravity-{{$randomInt}}" },
                  { "key": "X-Disabled-Header", "value": "Should-Not-Send", "disabled": true }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"uuid\": \"{{randomUUIDtimestamp}}\",\n  \"message\": \"Hello World\"\n}"
                },
                "url": {
                  "raw": "https://httpbin.org/post"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 200', () => pm.response.to.be.ok);",
                      "pm.test('Assert success status code', () => pm.response.to.be.success);",
                      "const json = pm.response.json();",
                      "pm.test('JSON payload echo works', () => {",
                      "  pm.expect(json.json.message).to.eql('Hello World');",
                      "  pm.expect(json.json.uuid).to.match(/^[0-9a-f-]{36}$/);",
                      "});",
                      "pm.test('Custom header was sent', () => {",
                      "  pm.expect(json.headers['X-Smoke-Test']).to.include('Antigravity-');",
                      "});",
                      "pm.test('Disabled header was skipped', () => {",
                      "  pm.expect(json.headers['X-Disabled-Header']).to.be.undefined;",
                      "});",
                      "pm.test('Response headers are queried successfully', () => {",
                      "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }